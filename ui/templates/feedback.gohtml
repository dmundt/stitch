{{define "alert"}}<aside class="alert alert-{{.Tone}}" role="status">{{.Text}}</aside>{{end}}

{{define "badge"}}<span class="badge badge-{{.Tone}}">{{.Text}}</span>{{end}}

{{define "button"}}<button class="btn btn-{{.Kind}}">{{.Text}}</button>{{end}}

{{define "card"}}<article class="card"><header><h3>{{.Title}}</h3></header><p>{{.Body}}</p></article>{{end}}
